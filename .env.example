# ============================================================
# 환경변수 템플릿. 복사해서 사용: cp .env.example .env
# 실제 .env는 절대 커밋하지 않는다 (.gitignore 처리됨).
# ============================================================

# ---------- PostgreSQL (공통) ----------
POSTGRES_DB=fashion_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# DATABASE_URL을 쓰면 위 개별 값 대신 우선 적용된다.
# DATABASE_URL=postgresql://postgres:change-me@localhost:5432/fashion_db

# ---------- 네이버 오픈 API (collector/naver) ----------
# https://developers.naver.com 에서 애플리케이션 등록 후 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 검색 옵션
NAVER_SORT=sim                       # sim | date | asc | dsc
NAVER_EXCLUDE=used:rental:cbshop     # 중고/렌탈/해외직구 제외
NAVER_MAX_ITEMS_PER_KEYWORD=300      # 키워드당 수집 상한 (API 한계: 1100)
NAVER_REQUEST_INTERVAL_SECONDS=0.15
# 키워드 성별 확장. 예: "남성,여성" → "남성 반팔 티셔츠" 등으로 확장 수집
NAVER_KEYWORD_GENDER_PREFIXES=

# ---------- OpenAI LLM 태깅 (collector/naver) ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# auto: 텍스트 태깅 부실 시 이미지 포함 재시도 / always / never
NAVER_LLM_IMAGE_MODE=auto
NAVER_LLM_TEMPERATURE=0.1
NAVER_LLM_MAX_RETRIES=2

# ---------- 네이버 collector 스케줄 (매일 KST) ----------
NAVER_SCHEDULE_HOUR=3
NAVER_SCHEDULE_MINUTE=0

# ---------- 기상청 APIHub (collector/weather) ----------
KMA_AUTH_KEY=
KMA_AUTH_PARAM_NAME=authKey
# MID_LAND_URL=
# MID_TEMP_URL=

# ---------- 공통 ----------
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30
COLLECTOR_MAX_RETRIES=3
