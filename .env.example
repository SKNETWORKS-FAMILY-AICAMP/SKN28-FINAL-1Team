# ============================================================
# 환경변수 템플릿. 복사해서 사용: cp .env.example .env
# 실제 .env는 절대 커밋하지 않는다 (.gitignore 처리됨).
# ============================================================

# ---------- PostgreSQL (공통) ----------
POSTGRES_DB=fashion_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# DATABASE_URL을 쓰면 위 개별 값 대신 우선 적용된다.
# DATABASE_URL=postgresql://postgres:change-me@localhost:5432/fashion_db

# ---------- 네이버 오픈 API (collector/naver) ----------
# https://developers.naver.com 에서 애플리케이션 등록 후 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 검색 옵션
NAVER_SORT=sim                       # sim | date | asc | dsc
NAVER_EXCLUDE=used:rental:cbshop     # 중고/렌탈/해외직구 제외
NAVER_MAX_ITEMS_PER_KEYWORD=300      # 키워드당 수집 상한 (API 한계: 1100)
NAVER_REQUEST_INTERVAL_SECONDS=0.15
# 키워드 성별 확장. 예: "남성,여성" → "남성 반팔 티셔츠" 등으로 확장 수집
NAVER_KEYWORD_GENDER_PREFIXES=

# ---------- OpenAI LLM 태깅 (collector/naver) ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# batch(기본): Batch API로 태깅 (50% 할인, 완료까지 최대 24h) / sync: 실시간 태깅
NAVER_TAGGING_MODE=batch
NAVER_BATCH_MAX_REQUESTS=10000
NAVER_BATCH_POLL_SECONDS=600
# 배치 요청에 상품 이미지 포함 여부 (gpt-4o-mini는 이미지 토큰 과금이 커서 기본 false)
NAVER_BATCH_INCLUDE_IMAGE=false
# sync 모드 전용 — auto: 텍스트 태깅 부실 시 이미지 포함 재시도 / always / never
NAVER_LLM_IMAGE_MODE=auto
NAVER_LLM_TEMPERATURE=0.1
NAVER_LLM_MAX_RETRIES=2

# ---------- 네이버 collector 스케줄 (매일 KST) ----------
NAVER_SCHEDULE_HOUR=3
NAVER_SCHEDULE_MINUTE=0

# ---------- Docker Compose ----------
# 루트 docker-compose.yml에서 띄울 스택 선택 (--profile 플래그 대신 사용 가능)
# 예: db,api / api,naver / all
COMPOSE_PROFILES=api

# ---------- Django API 서버 (api/) ----------
DJANGO_SECRET_KEY=change-me-generate-a-random-50-char-string
# 컨테이너 기본은 prod 설정. 로컬 http 테스트 시 dev로 변경(prod는 HTTPS 리다이렉트 활성).
DJANGO_SETTINGS_MODULE=config.settings.prod
# prod 필수. 콤마 구분: api.example.com,internal.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# 로컬 도커(http) 테스트 시 false. AWS(ALB+HTTPS) 배포 시 true.
DJANGO_SECURE_SSL_REDIRECT=false
GUNICORN_WORKERS=3
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14

# ---------- 소셜 로그인 OAuth (api/apps/users) ----------
# 검색 API용 NAVER_CLIENT_ID와 별개다. 네이버 개발자센터의 "네이버 로그인" 앱 키를 쓴다.
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
# 카카오는 REST API 키 사용. client_secret은 콘솔에서 활성화한 경우에만 설정.
KAKAO_OAUTH_REST_API_KEY=
KAKAO_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_REQUEST_TIMEOUT=10

# ---------- Qdrant 벡터 DB (api/apps/recommend) ----------
# 로컬 도커: http://localhost:6333 (compose 내부에서는 자동으로 http://qdrant:6333)
QDRANT_URL=http://localhost:6333
# 비우면 무인증(로컬 전용). EC2 등 외부 노출 시 반드시 설정.
QDRANT_API_KEY=
QDRANT_TIMEOUT=10
# 임베딩 차원 (모델 교체 시에만 변경: FashionSigLIP=768, BGE-M3=1024)
QDRANT_IMAGE_VECTOR_DIM=768
QDRANT_TEXT_VECTOR_DIM=1024

# ---------- 기상청 APIHub (collector/weather) ----------
KMA_AUTH_KEY=
KMA_AUTH_PARAM_NAME=authKey
# MID_LAND_URL=
# MID_TEMP_URL=

# ---------- 공통 ----------
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30
COLLECTOR_MAX_RETRIES=3
