# ============================================================
# 환경변수 템플릿. 복사해서 사용: cp .env.example .env
# 실제 .env는 절대 커밋하지 않는다 (.gitignore 처리됨).
# ============================================================

# ---------- PostgreSQL (공통) ----------
POSTGRES_DB=fashion_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# DATABASE_URL을 쓰면 위 개별 값 대신 우선 적용된다.
# DATABASE_URL=postgresql://postgres:change-me@localhost:5432/fashion_db

# ---------- 네이버 오픈 API (collector/naver) ----------
# https://developers.naver.com 에서 애플리케이션 등록 후 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 검색 옵션
NAVER_SORT=sim                       # sim | date | asc | dsc
NAVER_EXCLUDE=used:rental:cbshop     # 중고/렌탈/해외직구 제외
NAVER_MAX_ITEMS_PER_KEYWORD=300      # 키워드당 수집 상한 (API 한계: 1100)
NAVER_REQUEST_INTERVAL_SECONDS=0.15
# 키워드 성별 확장. 예: "남성,여성" → "남성 반팔 티셔츠" 등으로 확장 수집
NAVER_KEYWORD_GENDER_PREFIXES=

# ---------- LLM 태깅 (collector/naver → collector/util/tagging) ----------
# 태깅 provider: openai | claude
#   openai - OpenAI API (sync/batch 지원)
#   claude - Claude Agent SDK. 구독제(Pro/Max) 계정의 OAuth 토큰 사용, sync 전용
NAVER_TAGGING_PROVIDER=openai

# openai provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# claude provider — `claude setup-token`으로 발급한 구독 계정 OAuth 토큰
CLAUDE_CODE_OAUTH_TOKEN=
# 빈 값이면 Claude Code CLI 기본 모델 사용 (예: claude-haiku-4-5)
NAVER_CLAUDE_MODEL=
# Docker에서 claude provider 사용 시 true (이미지 빌드에 Claude Code CLI 포함)
INSTALL_CLAUDE_CLI=false
# batch(기본): Batch API로 태깅 (50% 할인, 완료까지 최대 24h) / sync: 실시간 태깅
NAVER_TAGGING_MODE=batch
NAVER_BATCH_MAX_REQUESTS=10000
NAVER_BATCH_POLL_SECONDS=600
NAVER_BATCH_COMPLETION_WINDOW=24h
# 배치 요청에 상품 이미지 포함 여부 (gpt-4o-mini는 이미지 토큰 과금이 커서 기본 false)
NAVER_BATCH_INCLUDE_IMAGE=false
# sync 모드 전용 — auto: 텍스트 태깅 부실 시 이미지 포함 재시도 / always / never
NAVER_LLM_IMAGE_MODE=auto
NAVER_LLM_TEMPERATURE=0.1
NAVER_LLM_MAX_RETRIES=2

# ---------- 네이버 collector 스케줄 (매일 KST) ----------
NAVER_SCHEDULE_HOUR=3
NAVER_SCHEDULE_MINUTE=0

# ---------- 11번가 ProductSearch API (collector/eleven) ----------
11ST_API_KEY=
ELEVEN_PRODUCT_SEARCH_URL=http://openapi.11st.co.kr/openapi/OpenApiService.tmall
ELEVEN_CATEGORY_API_URL=http://api.11st.co.kr/rest/cateservice/category
ELEVEN_SEARCH_SORT=N
ELEVEN_PAGE_SIZE=50
ELEVEN_MAX_ITEMS_PER_KEYWORD=300
ELEVEN_REQUEST_INTERVAL_SECONDS=0.2
ELEVEN_KEYWORD_GENDER_PREFIXES=
ELEVEN_CATEGORY_MAPPING_VERSION=2026-07-21-v1
# 전체 카테고리 동기화에서 연속 누락 후 is_active=false 처리하는 횟수
ELEVEN_CATEGORY_INACTIVE_MISS_THRESHOLD=3
# 수집 단계에서 OpenAI 동기 태깅. OPENAI_API_KEY/OPENAI_MODEL은 위 공통 값 사용.
ELEVEN_LLM_IMAGE_MODE=auto
ELEVEN_LLM_TEMPERATURE=0.1
ELEVEN_LLM_MAX_RETRIES=2
ELEVEN_SCHEDULE_HOUR=4
ELEVEN_SCHEDULE_MINUTE=0

# ---------- Docker Compose ----------
# 루트 docker-compose.yml에서 띄울 스택 선택 (--profile 플래그 대신 사용 가능)
# 예: db,api / api,naver / all
COMPOSE_PROFILES=api

# ---------- Django API 서버 (api/) ----------
DJANGO_SECRET_KEY=change-me-generate-a-random-50-char-string
# 컨테이너 기본은 prod 설정. 로컬 http 테스트 시 dev로 변경(prod는 HTTPS 리다이렉트 활성).
DJANGO_SETTINGS_MODULE=config.settings.prod
# prod 필수. 콤마 구분: api.example.com,internal.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# 로컬 도커(http) 테스트 시 false. AWS(ALB+HTTPS) 배포 시 true.
DJANGO_SECURE_SSL_REDIRECT=false
GUNICORN_WORKERS=3
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14

# ---------- 소셜 로그인 OAuth (api/apps/users) ----------
# 검색 API용 NAVER_CLIENT_ID와 별개다. 네이버 개발자센터의 "네이버 로그인" 앱 키를 쓴다.
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
# 카카오는 REST API 키 사용. client_secret은 콘솔에서 활성화한 경우에만 설정.
KAKAO_OAUTH_REST_API_KEY=
KAKAO_OAUTH_CLIENT_SECRET=
# token 방식 로그인(네이티브 앱 SDK) 검증용 앱 ID (카카오 콘솔 > 앱 설정 > 요약 정보의 숫자 ID)
KAKAO_APP_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# 애플: Apple Developer Console > Certificates, Identifiers & Profiles에서 발급
# APPLE_CLIENT_ID: Services ID (com.example.yourapp)
# APPLE_PRIVATE_KEY: "Sign in with Apple" 키 PEM 전체 내용 (\n을 실제 줄바꿈으로 입력)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
OAUTH_REQUEST_TIMEOUT=10

# ---------- Qdrant / indexer ----------
# indexer(S3 → 임베딩 → Qdrant)와 추후 추천 API가 사용
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=fashion_items
# S3 접근 자격증명 (EC2/RunPod에서 IAM 역할·프로파일이 없을 때만 설정)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-2
# INDEXER_S3_BUCKET=skn28-cozy
# INDEXER_DEVICE=auto                # auto | cuda | cpu
# INDEXER_BATCH_SIZE=64

# ---------- 기상청 APIHub (collector/weather) ----------
KMA_AUTH_KEY=
KMA_AUTH_PARAM_NAME=authKey
# MID_LAND_URL=
# MID_TEMP_URL=

# ---------- 공통 ----------
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30
COLLECTOR_MAX_RETRIES=3
