# GPU(RTX 3090 등) 환경용. 실행: docker run --gpus all --env-file .env skn28-indexer
FROM pytorch/pytorch:2.3.1-cuda12.1-cudnn8-runtime

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY *.py .

# HuggingFace 모델 캐시 (볼륨 마운트로 재사용 가능)
ENV HF_HOME=/app/.cache/huggingface

ENTRYPOINT ["python", "/app/fashion_indexer.py"]
