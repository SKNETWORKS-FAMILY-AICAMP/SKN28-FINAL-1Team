# 앱 프론트 환경변수 예시 — 복사해서 .env 로 쓰고, .env 는 커밋하지 않는다.
#   cp .env.example .env
#
# EXPO_PUBLIC_ 접두사 값은 앱 번들에 포함되는 "공개값"이다.
# (카카오 REST 키 / 네이버·구글 Client ID 는 공개 식별자라 앱에 둬도 된다.
#  client_secret 같은 비밀값은 백엔드 전용 — 여기에 절대 넣지 않는다.)

# 백엔드 API 주소. 실기기에서 로컬 백엔드에 붙으려면 localhost 대신 PC의 LAN IP.
EXPO_PUBLIC_API_URL=http://localhost:8000

# 소셜 로그인 공개 키/ID (각 개발자 콘솔에서 발급받아 채운다)
EXPO_PUBLIC_KAKAO_REST_API_KEY=
EXPO_PUBLIC_NAVER_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
