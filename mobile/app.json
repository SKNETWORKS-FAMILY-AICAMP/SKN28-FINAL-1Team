{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "owner": "skn-1st",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.cozy.mobile"
    },
    "android": {
      "package": "com.cozy.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "옷장에 사진을 추가하기 위해 앨범 접근이 필요해요.",
          "cameraPermission": "옷을 촬영해 추가하기 위해 카메라 접근이 필요해요."
        }
      ],
      [
        "@react-native-kakao/core",
        {
          "nativeAppKey": "1366adcd2e8c643a4b5471fabd32b6ea",
          "ios": {
            "handleKakaoOpenUrl": true
          },
          "android": {
            "authCodeHandlerActivity": true
          }
        }
      ],
      [
        "@react-native-seoul/naver-login",
        {
          "urlScheme": "cozynaverlogin"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.12014138361-9204huiqjo6bgrgcju22dac7jg2dculu"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://devrepo.kakao.com/nexus/content/groups/public/"
            ]
          }
        }
      ],
      "./plugins/withModularHeaders"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b95bedd-1211-478f-b12d-b284b4ab235a"
      }
    }
  }
}
