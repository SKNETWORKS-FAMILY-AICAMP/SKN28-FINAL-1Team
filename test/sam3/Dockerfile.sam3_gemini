# SAM 3 + Gemini 태깅 테스트 이미지 (GPU)
# 빌드:  ./build_sam3_gemini.sh
# 실행:  ./run_sam3_gemini.sh <이미지경로>
FROM pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime

WORKDIR /app

# 의존성 레이어를 소스와 분리해 코드 수정 시 재설치 방지
COPY requirements.sam3_gemini.txt .
RUN pip install --no-cache-dir -r requirements.sam3_gemini.txt

COPY test_sam3_gemini.py .

# sam3.pt는 HF gated 가중치라 이미지에 포함하지 않는다 → 런타임 볼륨 마운트
# 결과는 /app/output에 쓰므로 호스트 디렉터리를 마운트해 회수한다
ENTRYPOINT ["python", "test_sam3_gemini.py"]
